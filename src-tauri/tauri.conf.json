{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "두루마리",
  "version": "0.1.0",
  "identifier": "kr.durumari.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "두루마리",
      "width": 600,
      "height": 900,
      "minWidth": 600,
      "minHeight": 900,
      "center": true,
      "decorations": true,
      "resizable": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true },
      "wix": {
        "language": ["ko-KR"]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
